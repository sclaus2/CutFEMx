@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(OpenMP COMPONENTS CXX)
find_dependency(CutCells CONFIG)
find_dependency(DOLFINX CONFIG)
find_dependency(spdlog CONFIG)

if(NOT TARGET CUTFEMX::cutfemx)
  include("${CMAKE_CURRENT_LIST_DIR}/@PROJECT_NAME@Targets.cmake")
endif()

if(NOT TARGET cutfemx AND TARGET CUTFEMX::cutfemx)
  add_library(cutfemx ALIAS CUTFEMX::cutfemx)
endif()
